{
  "name": "tittel-tutoring-whiteboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Zero-login, ephemeral collaborative whiteboard for live tutoring. Tutor-driven shared camera.",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tldraw/sync": "3.15.5",
    "@tldraw/sync-core": "3.15.5",
    "express": "^4.19.2",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "katex": "^0.17.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "tldraw": "3.15.5",
    "tsx": "^4.19.1",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
